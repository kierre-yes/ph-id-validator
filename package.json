{
  "name": "@kierfr_atdev/ph-id-validator",
  "version": "0.1.2",
  "description": "TypeScript-first validation and formatting utilities for PH government IDs.",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "dev:test": "vitest",
    "check": "npm run build && npm run test",
    "prepublishOnly": "npm run check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kierre-yes/ph-id-validator.git"
  },
  "keywords": [
    "philippines",
    "validator",
    "typescript",
    "tin",
    "philhealth",
    "pagibig",
    "philsys",
    "id-validation"
  ],
  "author": "Kier Christian F. Reyes <reyeskierchristian64@gmail.com> (https://github.com/kierre-yes)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kierre-yes/ph-id-validator/issues"
  },
  "homepage": "https://github.com/kierre-yes/ph-id-validator#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
